{
  "manifest_version": 3,
  "name": "inton",
  "version": "1.1.0",
  "description": "AI 기반 기사 신뢰도와 제목 어그로 지수를 분석합니다.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.groq.com/*",
    "https://api.cerebras.ai/*"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "popup.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon48.png",
        "assets/logo.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "inton",
    "default_popup": "action_popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  }
}
